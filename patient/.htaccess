# ============================================================
# IVF Experts — Patient Portal (patient.ivfexperts.pk)
# NOTE: HTTPS is enforced at Hostinger subdomain level.
#       Do NOT add a RewriteRule HTTPS redirect here — it breaks local dev.
# ============================================================

Options -Indexes
RewriteEngine On

# ---- Block direct web access to includes and docs ----
RewriteRule ^includes(/.*)?$ - [F,L]
RewriteRule ^docs(/.*)?$ - [F,L]

# ---- Block sensitive files ----
<FilesMatch "\.(sql|log|env|bak|swp|sh|py|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
