# ============================================================
# IVF Experts — Admin EMR (4me.ivfexperts.pk)
# NOTE: HTTPS is enforced at Hostinger subdomain level.
#       Do NOT add a RewriteRule HTTPS redirect here — it breaks local dev.
# ============================================================

Options -Indexes
RewriteEngine On

# ---- Block direct web access to DB config ----
RewriteRule ^config(/.*)?$ - [F,L]

# ---- Block migration / setup scripts from web access ----
<FilesMatch "^(migrate_|master_migration|cleanup_ghost|schema_check|run_migration).*\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>


# ---- Block sensitive files ----
<FilesMatch "\.(sql|log|env|bak|swp|sh|py)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
